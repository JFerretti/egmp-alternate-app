/resources

# Google Play service account keys (for EAS submit)
# Matches both the canonical name and Google Cloud's auto-generated names
play-service-account.json
bluewink-play-*.json
*-service-account*.json

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
