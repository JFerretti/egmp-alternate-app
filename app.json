{
  "expo": {
    "name": "BlueWink",
    "slug": "bluewink",
    "version": "1.0.0",
    "description": "Unofficial third-party companion app for monitoring and controlling Hyundai and Kia electric vehicles. Check battery, range, and charging status, send remote commands (lock, climate, charging), and view live charging progress. Not affiliated with Hyundai Motor Company or Kia Corporation.",
    "privacy": "public",
    "orientation": "portrait",
    "icon": "./assets/images/bluewink_icon.png",
    "scheme": "bluewink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bluewink_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c2340"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/bluewink_icon.png",
        "backgroundColor": "#0c2340"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bluewink.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/bluewink_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c295b6b-33e7-4e87-8d6a-d60b9d26165f"
      }
    },
    "owner": "jferretti"
  }
}
