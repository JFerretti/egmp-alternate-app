# Bluelink API Testing
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real tokens.

# Hyundai Europe refresh token (required for recording fixtures & integration tests)
BLUELINK_REFRESH_TOKEN=

# Set to "true" to enable integration tests that hit the real API (read-only only)
BLUELINK_INTEGRATION=false
